{
  "name": "kkaeal_server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "dev:local": "cross-env NODE_ENV=local nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register --project tsconfig.json\" src/index.ts",
    "dev": "cross-env NODE_ENV=development nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register --project tsconfig.json\" src/index.ts",
    "dev:prod": "cross-env NODE_ENV=production nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register --project tsconfig.json\" src/index.ts",
    "build": "tsc && tsc-alias",
    "serve:dev": "cross-env NODE_ENV=development node -r tsconfig-paths/register dist/index.js",
    "serve": "cross-env NODE_ENV=production node -r tsconfig-paths/register dist/index.js",
    "start:dev": "npm run serve:dev",
    "start": "npm run serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stART010/kkaeal_server.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/stART010/kkaeal_server/issues"
  },
  "homepage": "https://github.com/stART010/kkaeal_server#readme",
  "dependencies": {
    "@google-cloud/logging-winston": "^6.0.0",
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "firebase": "^11.6.1",
    "firebase-admin": "^13.3.0",
    "module-alias": "^2.2.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
